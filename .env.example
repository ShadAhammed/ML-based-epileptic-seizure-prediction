# ---------------------------------------------------------------------------
# Local paths only — never commit .env, data/, models/, or reports/ to GitHub.
# How to obtain EEG data: see docs/DATA.md (PhysioNet CHB-MIT credentialing).
# ---------------------------------------------------------------------------

# Directory containing CHB-MIT EDF recordings (download separately; gitignored)
EPILEPSY_DATA_DIR=./data/raw

# Trained model output directory
EPILEPSY_MODEL_DIR=./models

# Reports and evaluation outputs
EPILEPSY_REPORTS_DIR=./reports

# Optional custom config
# EPILEPSY_CONFIG_PATH=./config/default.yaml
